cumentation\u003e","            The organisations that organise the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Official\" type=\"Role\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The main officials of the event, e.g. course setter and event president.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Service\" type=\"Service\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The services available for the race, e.g. accomodation and transport.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"URL\" type=\"EventURL\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            URLs to various types of additional information regarding the event, e.g. event website or result list.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:simpleType name=\"EventClassification\"\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","