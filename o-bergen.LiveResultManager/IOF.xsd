complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  \u003cxsd:element name=\"CourseData\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        This element defines all the control and course information for an event or race. Used when transferring courses from course-setting software to event administration software.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexType\u003e","      \u003cxsd:complexContent\u003e","        \u003cxsd:extension base=\"BaseMessageElement\"\u003e","          \u003cxsd:sequence\u003e","            \u003cxsd:element name=\"Event\" type=\"Event\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The event that the course data belongs to.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"RaceCourseData\" type=\"RaceCourseData\" minOccurs=\"1\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The course data for each race; one element per race in the event.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Container element for custom elements from other schemas.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","          \u003c/xsd:sequence\u003e","        \u003c/xsd:extension\u003e","      \u003c/xsd:complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  \u003cxsd:element name=\"StartList\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Contains information about the start lists for the classes in an event.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexType\u003e","      \u003cxsd:complexContent\u003e","        \u003cxsd:extension base=\"BaseMessageElement\"\u003e","          \u003cxsd:sequence\u003e","            \u003cxsd:element name=\"Event\" type=\"Event\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The event that the start lists belong to.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"ClassStart\" type=\"ClassStart\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Start lists for the classes in the event.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Container element for custom elements from other schemas.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","          \u003c/xsd:sequence\u003e","        \u003c/xsd:extension\u003e","      \u003c/xsd:complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  \u003cxsd:element name=\"ResultList\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Contains information about the result lists for the classes in an event.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexType\u003e","      \u003cxsd:complexContent\u003e","        \u003cxsd:extension base=\"BaseMessageElement\"\u003e","          \u003cxsd:sequence\u003e","            \u003cxsd:element name=\"Event\" type=\"Event\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The event that the result lists belong to.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"ClassResult\" type=\"ClassResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Result lists for the classes in the event.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Container element for custom elements from other schemas.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","          \u003c/xsd:sequence\u003e","          \u003cxsd:attribute name=\"status\" use=\"optional\" default=\"Complete\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The status of the result list.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","            \u003cxsd:simpleType\u003e","              \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","                \u003cxsd:enumeration value=\"Complete\"\u003e","                  \u003cxsd:annotation\u003e","                    \u003cxsd:documentation\u003e","                      The result list is complete, i.e. all competitors are included. Used for official results after the event.","                    \u003c/xsd:documentation\u003e","                  \u003c/xsd:annotation\u003e","                \u003c/xsd:enumeration\u003e","                \u003cxsd:enumeration value=\"Delta\"\u003e","                  \u003cxsd:annotation\u003e","                    \u003cxsd:documentation\u003e","                      The result list only contains changes since last list. Used for frequent exchange of results.","                    \u003c/xsd:documentation\u003e","                  \u003c/xsd:annotation\u003e","                \u003c/xsd:enumeration\u003e","                \u003cxsd:enumeration value=\"Snapshot\"\u003e","                  \u003cxsd:annotation\u003e","                    \u003cxsd:documentation\u003e","                      The result list is a snapshot of the current standings. Used while the event is under way.","                    \u003c/xsd:documentation\u003e","                  \u003c/xsd:annotation\u003e","                \u003c/xsd:enumeration\u003e","              \u003c/xsd:restriction\u003e","            \u003c/xsd:simpleType\u003e","          \u003c/xsd:attribute\u003e","        \u003c/xsd:extension\u003e","      \u003c/xsd:complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  \u003cxsd:element name=\"ServiceRequestList\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        A list of service requests.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexType\u003e","      \u003cxsd:complexContent\u003e","        \u003cxsd:extension base=\"BaseMessageElement\"\u003e","          \u003cxsd:sequence\u003e","            \u003cxsd:element name=\"Event\" type=\"Event\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The event that the service requests are valid for.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"OrganisationServiceRequest\" type=\"OrganisationServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Service requests made by organisations.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"PersonServiceRequest\" type=\"PersonServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Service requests made by persons.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Container element for custom elements from other schemas.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","          \u003c/xsd:sequence\u003e","        \u003c/xsd:extension\u003e","      \u003c/xsd:complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  \u003cxsd:element name=\"ControlCardList\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines control card ownership, e.g. for rental control card handling purposes.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexType\u003e","      \u003cxsd:complexContent\u003e","        \u003cxsd:extension base=\"BaseMessageElement\"\u003e","          \u003cxsd:sequence\u003e","            \u003cxsd:element name=\"Owner\" type=\"xsd:string\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The owner of the control cards.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" maxOccurs=\"unbounded\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  The control cards.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","            \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","              \u003cxsd:annotation\u003e","                \u003cxsd:documentation\u003e","                  Container element for custom elements from other schemas.","                \u003c/xsd:documentation\u003e","              \u003c/xsd:annotation\u003e","            \u003c/xsd:element\u003e","          \u003c/xsd:sequence\u003e","        \u003c/xsd:extension\u003e","      \u003c/xsd:complexContent\u003e","    \u003c/xsd:complexType\u003e","  \u003c/xsd:element\u003e","","  ","  \u003c!-- DATA ELEMENTS --\u003e","","  \u003cxsd:complexType name=\"Id\" mixed=\"false\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Identifier element, used extensively. The id should be known and common for both systems taking part in the data exchange.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:extension base=\"xsd:string\"\u003e","        \u003cxsd:attribute name=\"type\" type=\"xsd:string\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The issuer of the identity, e.g. World Ranking List.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Person\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Represents a person. This could either be a competitor (see the Competitor element) or contact persons in an organisation (see the Organisation element).","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The identifier of the person. Multiple identifiers can be included, e.g. when there is both a World Ranking Event identifier and a national database identifier for the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"PersonName\"/\u003e","      \u003cxsd:element name=\"BirthDate\" type=\"xsd:date\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The date when the person was born, expressed in ISO 8601 format.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Nationality\" type=\"Country\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Address\" type=\"Address\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Contact\" type=\"Contact\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"sex\" use=\"optional\"\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"F\"/\u003e","          \u003cxsd:enumeration value=\"M\"/\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonName\"\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Family\" type=\"xsd:string\"/\u003e","      \u003cxsd:element name=\"Given\" type=\"xsd:string\"/\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Competitor\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Represents information about a person in a competition context, i.e. including organisation and control card.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\"/\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisations that the person is member of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The default control cards of the competitor.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The default classes of the competitor.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any scores, e.g. ranking scores, for the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ControlCard\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The unique identifier of the control card, i.e. card number.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:extension base=\"xsd:string\"\u003e","        \u003cxsd:attribute name=\"punchingSystem\" type=\"xsd:string\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The manufacturer of the punching system, e.g. 'SI' or 'Emit'.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","        \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Score\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The score earned in an event for some purpose, e.g. a ranking list. The 'type' attribute is used to specify which purpose.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:extension base=\"xsd:double\"\u003e","        \u003cxsd:attribute name=\"type\" type=\"xsd:string\" use=\"optional\"/\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Organisation\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Information about an organisation, i.e. address, contact person(s) etc. An organisation is a general term including federations, clubs, etc.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The full name of the organisation.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ShortName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The short (abbreviated) name of the organisation.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MediaName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the organisation as appearing in result lists targeted to media.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ParentOrganisationId\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id of the parent of this organisation, e.g. a regional organisation for a club.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Country\" type=\"Country\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Address\" type=\"Address\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Contact\" type=\"Contact\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Position\" type=\"GeoPosition\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The geographical location of the organisation, e.g. a city center, an office or a club house.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Account\" type=\"Account\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Role\" type=\"Role\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Persons having certain roles within the organisation, e.g. chairman, secretary, and treasurer.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Logotype\" type=\"Image\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The logotype for the organisation. Multiple logotypes may be included; in this case, make sure to include width and height attributes.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The hierarchical level or type of an organisation.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"IOF\"/\u003e","          \u003cxsd:enumeration value=\"IOFRegion\"/\u003e","          \u003cxsd:enumeration value=\"NationalFederation\"/\u003e","          \u003cxsd:enumeration value=\"NationalRegion\"/\u003e","          \u003cxsd:enumeration value=\"Club\"/\u003e","          \u003cxsd:enumeration value=\"School\"/\u003e","          \u003cxsd:enumeration value=\"Company\"/\u003e","          \u003cxsd:enumeration value=\"Military\"/\u003e","          \u003cxsd:enumeration value=\"Other\"/\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Role\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        A role defines a connection between a person and some kind of task, responsibility or engagement, e.g. being a course setter at an event.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\"/\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" type=\"xsd:string\" use=\"required\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of role that the person has.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Event\" mixed=\"false\"\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"/\u003e","      \u003cxsd:element name=\"StartTime\" type=\"DateAndOptionalTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The start time for the first starting competitor of the event. If the event contains multiple races, this is the start time for the first starting competitor of the first race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"EndTime\" type=\"DateAndOptionalTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The expected finish time for the last finishing competitor of the event. If the event contains multiple races, this is the expected finish time for the last finishing competitor of the last race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Status\" type=\"EventStatus\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The status of the event. If the event is a multi-race event, and status is set per race, use the Status element of the Race element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Classification\" type=\"EventClassification\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The classification or level of the event. If the event is a multi-race event, and classification is set per race, use the Classification element of the Race element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Form\" type=\"EventForm\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Organiser\" type=\"Organisation\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisations that organise the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Official\" type=\"Role\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The main officials of the event, e.g. course setter and event president.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The classes that are available at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Race\" type=\"Race\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            An event consists of a number of races. The number is equal to the number of times a competitor should start. Most events contain a single race, and this elemend could then be omitted.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"EntryReceiver\" type=\"EntryReceiver\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Address and contact information to the person or organisation which registers the entries for the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Service\" type=\"Service\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The services available for the event, e.g. accomodation and transport.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Account\" type=\"Account\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bank account for the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"URL\" type=\"EventURL\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            URLs to various types of additional information regarding the event, e.g. event website or result list.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Information\" type=\"InformationItem\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Presents arbitrary data about the event, e.g. \"Accommodation\", \"Local Attractions\", and so on. Information present here should be defined well in advance of the event, in contrast to the 'News' element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Schedule\" type=\"Schedule\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the schedule of events that comprise the entire orienteering event, e.g. entry deadlines, banquet and social events, and awards ceremonies.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"News\" type=\"InformationItem\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Presents \"last minute information\" about the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"EntryReceiver\"\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Address\" type=\"Address\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","      \u003cxsd:element name=\"Contact\" type=\"Contact\" minOccurs=\"0\" maxOccurs=\"unbounded\"/\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:simpleType name=\"EventForm\"\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","      \u003cxsd:enumeration value=\"Individual\"/\u003e","      \u003cxsd:enumeration value=\"Team\"/\u003e","      \u003cxsd:enumeration value=\"Relay\"/\u003e","    \u003c/xsd:restriction\u003e","  \u003c/xsd:simpleType\u003e","","  \u003cxsd:simpleType name=\"EventStatus\"\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","      \u003cxsd:enumeration value=\"Planned\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The event or race is on a planning stadium and has not been submitted to any sanctioning body.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Applied\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organiser has submitted the event to the relevant sanctioning body.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Proposed\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organiser has bid on hosting the event or race as e.g. a championship.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Sanctioned\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The event oc race meets the relevant requirements and will happen.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Canceled\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The event or race has been canceled, e.g. due to weather conditions.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Rescheduled\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The date of the event or race has changed. A new Event or Race element should be created in addition to the already existing element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","    \u003c/xsd:restriction\u003e","  \u003c/xsd:simpleType\u003e","","  \u003cxsd:complexType name=\"Race\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        An event consists of a number of races. The number is equal to the number of times a competitor should start.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"RaceNumber\" type=\"xsd:integer\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The ordinal number of the race in the multi-race event, starting at 1.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"/\u003e","      \u003cxsd:element name=\"StartTime\" type=\"DateAndOptionalTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","    