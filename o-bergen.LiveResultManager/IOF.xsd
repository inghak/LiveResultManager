ment\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" type=\"xsd:string\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Used to mark special services, e.g. rental cards whose fees that are to be used in entry scenarios.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"OrganisationServiceRequest\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Service requests made by an organisation.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that made the requests.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The service requests that the organisation made.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PersonServiceRequest\" type=\"PersonServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The service requests made by persons representing the organisation.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonServiceRequest\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Service requests made by a person.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The person that made the requests.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The service requests.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ServiceRequest\"\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Service\" type=\"Service\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The service that is requested.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"RequestedQuantity\" type=\"xsd:double\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The quantity (number of instances) of the service that is requested.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"DeliveredQuantity\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u00