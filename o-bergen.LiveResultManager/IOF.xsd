type=\"xsd:dateTime\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The start time of the sub-event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"EndTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The end time of the sub-event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name or title of the sub-event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Venue\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the place where the sub-event occurs.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Position\" type=\"GeoPosition\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The geographical position of the sub-event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Details\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any extra information about the sub-event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"InformationItem\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a general-purpose information object containing a title and content.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Title\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            A short summary of the information.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Content\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The information in detailed form.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Class\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a class in an event.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ShortName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The abbreviated name of a class, used when space is limited.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ClassType\" type=\"ClassType\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class type(s) for the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Leg\" type=\"Leg\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Information about the legs, if the class is a relay class. One Leg element per leg must be present.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamFee\" type=\"Fee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The entry fees for a team as a whole taking part in this class. Use the Fee element to specify a fee for an individual competitor in the team. Use the TeamFee subelement of the RaceClass element to specify a fee on race level.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Fee\" type=\"Fee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The entry fees for an individual competitor taking part in the class. Use the TeamFee element to specify a fee for the team as a whole. Use the Fee subelement of the RaceClass element to specify a fee on race level.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Status\" type=\"EventClassStatus\" minOccurs=\"0\" default=\"Normal\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The overall status of the class, e.g. if overall results should be considered invalid due to misplaced controls.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"RaceClass\" type=\"RaceClass\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Race-specific information for the class, e.g. course(s) assigned to the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TooFewEntriesSubstituteClass\" type=\"Class\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class that competitors in this class should be transferred to if there are too few entries in this class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TooManyEntriesSubstituteClass\" type=\"Class\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class that competitors that are not qualified (e.g. due to too low ranking) should be transferred to if there are too many entries in this class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"minAge\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The lowest allowed age for a competitor taking part in the class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxAge\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The highest allowed age for a competitor taking part in the class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"sex\" use=\"optional\" default=\"B\"\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"B\"/\u003e","          \u003cxsd:enumeration value=\"F\"/\u003e","          \u003cxsd:enumeration value=\"M\"/\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"minNumberOfTeamMembers\" type=\"xsd:integer\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The minimum number of members in a team taking part in the class, if the class is a team class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxNumberOfTeamMembers\" type=\"xsd:integer\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The maximum number of members in a team taking part in the class, if the class is a team class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"minTeamAge\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The lowest allowed age sum of the team members for a team taking part in the class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxTeamAge\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The highest allowed age sum of the team members for a team taking part in the class.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"numberOfCompetitors\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The number of competitors in the class. A competitor corresponds to a person (if an individual event) or a team (if a team or relay event).","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxNumberOfCompetitors\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The maximum number of competitors that are allowed to take part in the class. A competitor corresponds to a person (if an individual event) or a team (if a team or relay event). If the maximum number of competitors varies between races in a multi-day event, use the maxNumberOfCompetitors attribute in the RaceClass element.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"resultListMode\" use=\"optional\" default=\"Default\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Defines the kind of information to include in the result list, and how to sort it. For example, the result list of a beginner's class may include just \"finished\" or \"did not finish\" instead of the actual times.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"Default\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The result list should include place and time for each competitor, and be ordered by place.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"Unordered\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The result list should include place and time for each competitor, but be unordered with respect to times (e.g. sorted by competitor name).","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"UnorderedNoTimes\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The result list should not include any places and times, and be unordered with respect to times (e.g. sorted by competitor name).","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ClassType\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a class type, which is used to group classes in categories.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the class type.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:simpleType name=\"EventClassStatus\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The status of the class.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","      \u003cxsd:enumeration value=\"Normal\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The default status.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Divided\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class has been divided in two or more classes due to a large number of entries.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Joined\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class has been joined with another class due to a small number of entries.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Invalidated\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The results are considered invalid due to technical issues such as misplaced controls. Entry fees are not refunded.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"InvalidatedNoFee\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The results are considered invalid due to technical issues such as misplaced controls. Entry fees are refunded.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","    \u003c/xsd:restriction\u003e","  \u003c/xsd:simpleType\u003e","","  \u003cxsd:simpleType name=\"RaceClassStatus\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The status of a certain race in the class.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","      \u003cxsd:enumeration value=\"StartTimesNotAllocated\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The start list draw has not been made for this class in this race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"StartTimesAllocated\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The start list draw has been made for this class in this race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"NotUsed\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class is not organised in this race, e.g. for classes that are organised in only some of the races in a multi-race event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Completed\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The result list is complete for this class in this race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Invalidated\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The results are considered invalid due to technical issues such as misplaced controls. Entry fees are not refunded.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"InvalidatedNoFee\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The results are considered invalid due to technical issues such as misplaced controls. Entry fees are refunded.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","    \u003c/xsd:restriction\u003e","  \u003c/xsd:simpleType\u003e","","  \u003cxsd:complexType name=\"RaceClass\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Information about a class with respect to a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"PunchingSystem\" type=\"xsd:string\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The punching system used for the class at the race. Multiple punching systems can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamFee\" type=\"Fee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The entry fees for a team as a whole taking part in this class. Use the Fee element to specify a fee for an individual competitor in the team. Use the TeamFee subelement of the Class element to specify a fee on event level.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Fee\" type=\"Fee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The entry fees for an individual competitor taking part in the race class. Use the TeamFee element to specify a fee for the team as a whole. Use the Fee subelement of the Class element to specify a fee on event level.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"FirstStart\" type=\"xsd:dateTime\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Status\" type=\"RaceClassStatus\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The status of the race, e.g. if results should be considered invalid due to misplaced constrols.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleCourse\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The courses assigned to this class. For a mass-start event or a relay event, there are usually multiple courses per class due to the usage of spreading methods.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"OnlineControl\" type=\"Control\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The controls that are online controls for this class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxNumberOfCompetitors\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The maximum number of competitors that are allowed to take part in the race class. A competitor corresponds to a person (if an individual event) or a team (if a team or relay event). This attribute overrides the maxNumberOfCompetitors attribute in the Class element.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Fee\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        A fee that applies when entering a class at a race or ordering a service.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"LanguageString\" minOccurs=\"1\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            A describing name of the fee, e.g. 'Late entry fee'.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Amount\" type=\"Amount\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fee amount, optionally including currency code. This element must not be present if a Percentage element exists.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TaxableAmount\" type=\"Amount\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fee amount that is taxable, i.e. considered when calculating taxes for an event. This element must not be present if a Percentage element exists, or if an Amount element does not exist.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Percentage\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The percentage to increase or decrease already existing fees in a fee list with. This element must not be present if an Amount element exists.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TaxablePercentage\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The percentage to increase or decrease already existing taxable fees in a fee list with. This element must not be present if an Amount element exists, or if a Percentage element does not exist.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ValidFromTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the fee takes effect.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ValidToTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the fee expires.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"FromDateOfBirth\" type=\"xsd:date\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The start of the birth date interval that the fee should be applied to. Omit if no lower birth date restriction.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ToDateOfBirth\" type=\"xsd:date\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The end of the birth date interval that the fee should be applied to. Omit if no upper birth date restriction.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" use=\"optional\" default=\"Normal\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of fee.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"Normal\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The fee is a normal fee (i.e. not a late entry fee).","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"Late\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Te fee is a late entry fee.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"AssignedFee\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Contains information about a fee that has been assigned to a competitor or a team, and the amount that has been paid.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Fee\" type=\"Fee\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fee that has been assigned to the competitor or the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PaidAmount\" type=\"Amount\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The amount that has been paid, optionally including currency code.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","  ","  \u003cxsd:complexType name=\"Amount\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a monetary amount.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:extension base=\"xsd:decimal\"\u003e","        \u003cxsd:attribute name=\"currency\" type=\"xsd:string\" use=\"optional\"/\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonEntry\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines an event entry for a person.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The person that is entered.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the person represents at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Information about the control cards (punching cards) that the person uses at the event. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any score that is submitted together with the entry, e.g. World Ranking points.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class(es) the person wants to take part in. Multiple classes may be provided in order of preference in scenarios where the number of competitors are limited in some classes.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"RaceNumber\" type=\"xsd:integer\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The ordinal numbers of the races that the person is taking part in, starting at 1. If not specified, the person takes part in all races.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fees that the person has to pay when entering the event. In a multi-race event, there is usually one element for each race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTimeAllocationRequest\" type=\"StartTimeAllocationRequest\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any special preferences regarding start time that has to be taken into consideration when making the start list draw.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"EntryTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the entry was first submitted.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamEntry\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines an event entry for a team.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the team. If a relay, this is probably the name of the club optionally followed by a sequence number to distinguish teams from the same club in a class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation(s) that the team represents.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamEntryPerson\" type=\"TeamEntryPerson\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The persons that make up the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class(es) the team wants to take part in. Multiple classes may be provided in order of preference in scenarios where the number of competitors are limited in some classes.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Race\" type=\"xsd:integer\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The numbers of the races that the team is taking part in. If not specified, team person takes part in all races.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fees that the team as a whole has to pay when entering the event. In a multi-race event, there is usually one element for each race. If there are differentated fees for the team members, specify them in the TeamEntryPerson elements.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTimeAllocationRequest\" type=\"StartTimeAllocationRequest\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any special preferences regarding start time that has to be taken into consideration when making the start list draw.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ContactInformation\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Contact information (name and e.g. mobile phone number) to a team leader or coach, expressed as plain text.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"EntryTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the entry was first submitted.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamEntryPerson\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a person that is part of a team entry.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The person. Omit if the person is not known at the moment, but for example the control card is known.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the person represent. Omit if this is the same as the organsiation given in the TeamEntry element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Leg\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            For relay entries, the number of the leg that this person is taking part in.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"LegOrder\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the person's starting order within a team at a parallel relay leg.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Information about the control cards (punching cards) that the person uses at the event. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any score that is submitted together with the entry, e.g. World Ranking points.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The fees that this particular person has to pay when entering the event. In a multi-race event, there is usually one element for each race. Fees assigned to the team as a whole should be defined in the TeamEntry element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"StartTimeAllocationRequest\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Used to state start time allocation requests. It consists of a possible reference Organisation or Person and the allocation request, e.g. late start or grouped with the reference Organisation/Person. This way it is possible to state requests to the event organizer so that e.g. all members of an organisation has start times close to each other - or parents have start times far from each other. It is totally up to the event software and organizers whether they will support such requests.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The reference organisation for the start time allocation request.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The reference person for the start time allocation request.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" use=\"optional\" default=\"Normal\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of start time allocation request.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"Normal\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                No special preference; use normal start time allocations.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"EarlyStart\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The competitor preferences an early start time.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"LateStart\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The competitor preferences a late start time.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"SeparatedFrom\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The competitor preferences to start well separated in time from the person or organisation that is given by the Person or Organisation element.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"GroupedWith\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                The competitor preferences to start close in time from the person or organisation that is given by the Person or Organisation element.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ClassStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The start list of a single class containing either individual start times or team start times.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class that the start list belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleRaceCourse\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the class. If courses are unique per competitor, use PersonStart/Course or TeamStart/TeamMemberStart/Course instead. One element per race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartName\" type=\"StartName\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the name of the start place (e.g. Start 1), if the race has multiple start places. One element per race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PersonStart\" type=\"PersonStart\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Start times for individual competitors in the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamStart\" type=\"TeamStart\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Start times for teams in the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"timeResolution\" type=\"xsd:double\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The time resolution of the start times, normally 1. For tenths of a second, use 0.1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"StartName\"\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Defines the name of the start place (e.g. Start 1), if the race has multiple start places.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:extension base=\"xsd:string\"\u003e","        \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Start information for an individual competitor, including e.g. start time and bib number.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this person's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The person that the start time belongs to. Omit if there is no person assigned to the start time, e.g. a vacant person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the person is representing at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Start\" type=\"PersonRaceStart\" minOccurs=\"1\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The core start information for the person; one element per race in the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonRaceStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Start information for a person in a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the person is wearing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the person starts.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleCourse\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the control cards assigned to the person. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the person has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Start information for a team, including e.g. team name, start times and bib numbers.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this team's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the team, e.g. organisation name and team number for a relay team. Omit if the team name is not know, e.g. a vacant team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation(s) the team is representing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the members of the team are wearing. If each team member has a unique bib number, use the BibNumber of the TeamMemberStart element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamMemberStart\" type=\"TeamMemberStart\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Information about the start times for the team members. One element per relay leg must be included, even if the team has not assigned any team member to the leg.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the team has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamMemberStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Start information for an individual competitor, including e.g. start time and bib number.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this team member's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The team member that the start time belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the team member is representing at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Start\" type=\"TeamMemberRaceStart\" minOccurs=\"1\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The core start information for the team member; one element per race in the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamMemberRaceStart\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Start information for a team member in a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Leg\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            In case of a relay, this is the number of the leg that the team member takes part in.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"LegOrder\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            In case of a relay with parallel legs, this defines the team member's starting order of the leg within the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the team member is wearing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the team member starts.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleCourse\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the team member.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the control card assigned to the team member. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the team member has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the team member.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ClassResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The result list for a single class containing either individual results or team results.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Class\" type=\"Class\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The class that the result list belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleRaceCourse\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the class. If courses are unique per competitor, use PersonResult/Course or TeamResult/TeamMemberResult/Course instead. One element per race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PersonResult\" type=\"PersonResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Results for individual competitors in the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamResult\" type=\"TeamResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Results for teams in the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"timeResolution\" type=\"xsd:double\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The time resolution of the results, normally 1. For tenths of a second, use 0.1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Result information for an individual competitor, including e.g. result status, place, finish time, and split times.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this person's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The person that the result belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the person is representing at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Result\" type=\"PersonRaceResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The core result information for the person; one element per race in the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonRaceResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Result information for a person in a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the person that the result belongs to is wearing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the person that the result belongs to started, expressed in ISO 8601 format.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"FinishTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the person that the result belongs to finished, expressed in ISO 8601 format.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Time\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that is shown in the result list. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TimeBehind\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that the the person is behind the winner. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Position\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position in the result list for the person that the result belongs to. This element should only be present when the Status element is set to OK.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Status\" type=\"ResultStatus\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The status of the result.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any scores that are attached to the result, e.g. World Ranking points.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"OverallResult\" type=\"OverallResult\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Holds the overall result for the person after the current race for a multi-race event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleCourse\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"SplitTime\" type=\"SplitTime\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Contains the times at each control of the course. Each control of the competitor's course (if known) has to be defined in a SplitTime element, even if the control has not been punched or if the competitor has not started. Start and finish times must not be present as SplitTime elements.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlAnswer\" type=\"ControlAnswer\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the answer for a trail-O control.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Route\" type=\"Route\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the person's route recorded by a tracking device.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the control card assigned to the person. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the person has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Result information for a team, including e.g. result status, place, finish time and individual times for the team members.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this team's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the team, e.g. organisation name and team number for a relay team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation(s) the team is representing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the members of the team are wearing. If each team member has a unique bib number, use the BibNumber of the TeamMemberStart element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamMemberResult\" type=\"TeamMemberResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the result information for each team member. One element per relay leg must be included, even if the team has not assigned any team member to the leg.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the team has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamMemberResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Result information for a team member, including e.g. result status, place, finish time, and split times.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this team member's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Person\" type=\"Person\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The team member that the result belongs to. If a relay team is missing a team member, omit this element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Organisation\" type=\"Organisation\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The organisation that the team member is representing at the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Result\" type=\"TeamMemberRaceResult\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The core result information for the person; one element per race in the event.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamMemberRaceResult\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Result information for a person in a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Leg\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            In case of a relay, this is the number of the leg that the team member takes part in.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"LegOrder\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            In case of a relay with parallel legs, this defines the team member's starting order of the leg within the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number that the team member that the result belongs to is wearing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"StartTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the team member that the result belongs to started, expressed in ISO 8601 format.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"FinishTime\" type=\"xsd:dateTime\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time when the team member that the result belongs to finished, expressed in ISO 8601 format.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Time\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that is shown in the result list. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TimeBehind\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that the the team member is behind the winner. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","        \u003cxsd:complexType mixed=\"false\"\u003e","          \u003cxsd:simpleContent\u003e","            \u003cxsd:extension base=\"xsd:double\"\u003e","              \u003cxsd:attribute name=\"type\" use=\"required\"\u003e","                \u003cxsd:simpleType\u003e","                  \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","                    \u003cxsd:enumeration value=\"Leg\"\u003e","                      \u003cxsd:annotation\u003e","                        \u003cxsd:documentation\u003e","                          The time behind refers to the best time of the competitors that are taking part on the same leg as this team member, independly of the course assigned.","                        \u003c/xsd:documentation\u003e","                      \u003c/xsd:annotation\u003e","                    \u003c/xsd:enumeration\u003e","                    \u003cxsd:enumeration value=\"Course\"\u003e","                      \u003cxsd:annotation\u003e","                        \u003cxsd:documentation\u003e","                          The time behind refers to the best time of the competitors that have been assigned the same course as this team member.","                        \u003c/xsd:documentation\u003e","                      \u003c/xsd:annotation\u003e","                    \u003c/xsd:enumeration\u003e","                  \u003c/xsd:restriction\u003e","                \u003c/xsd:simpleType\u003e","              \u003c/xsd:attribute\u003e","            \u003c/xsd:extension\u003e","          \u003c/xsd:simpleContent\u003e","        \u003c/xsd:complexType\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Position\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position in the result list for the person that the result belongs to. This element should only be present when the Status element is set to OK.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","        \u003cxsd:complexType mixed=\"false\"\u003e","          \u003cxsd:simpleContent\u003e","            \u003cxsd:extension base=\"xsd:integer\"\u003e","              \u003cxsd:attribute name=\"type\" use=\"required\"\u003e","                \u003cxsd:simpleType\u003e","                  \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","                    \u003cxsd:enumeration value=\"Leg\"\u003e","                      \u003cxsd:annotation\u003e","                        \u003cxsd:documentation\u003e","                          The position refers to all competitors that are taking part on the same leg as this team member, independly of the course assigned.","                        \u003c/xsd:documentation\u003e","                      \u003c/xsd:annotation\u003e","                    \u003c/xsd:enumeration\u003e","                    \u003cxsd:enumeration value=\"Course\"\u003e","                      \u003cxsd:annotation\u003e","                        \u003cxsd:documentation\u003e","                          The position refers to all competitors that have been assigned the same course as this team member.","                        \u003c/xsd:documentation\u003e","                      \u003c/xsd:annotation\u003e","                    \u003c/xsd:enumeration\u003e","                  \u003c/xsd:restriction\u003e","                \u003c/xsd:simpleType\u003e","              \u003c/xsd:attribute\u003e","            \u003c/xsd:extension\u003e","          \u003c/xsd:simpleContent\u003e","        \u003c/xsd:complexType\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Status\" type=\"ResultStatus\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The status of the result.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any scores that are attached to the result, e.g. World Ranking points.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"OverallResult\" type=\"OverallResult\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Holds the result after the current leg for the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"SimpleCourse\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the course assigned to the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"SplitTime\" type=\"SplitTime\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Contains the times at each control of the course. Each control of the team member's course has to be defined in a SplitTime element, even if the control has not been punched. Start and finish times must not be present as SplitTime elements.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlAnswer\" type=\"ControlAnswer\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the answer for a trail-O control.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Route\" type=\"Route\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the person's route recorded by a tracking device.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ControlCard\" type=\"ControlCard\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the control card assigned to the person. Multiple control cards can be specified, e.g. one for punch checking and another for timing.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AssignedFee\" type=\"AssignedFee\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the fees that the team member has been assigned.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ServiceRequest\" type=\"ServiceRequest\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the services requested by the team member.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"OverallResult\"\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Time\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that is shown in the result list. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TimeBehind\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, that the the person or team is behind the leader or winner. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Position\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position in the result list for the person or team that the result belongs to. This element should only be present when the Status element is set to OK.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Status\" type=\"ResultStatus\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The status of the result.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"Score\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Any scores that are attached to the result, e.g. World Ranking points.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:simpleType name=\"ResultStatus\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        The result status of the person or team at the time of the result generation.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","      \u003cxsd:enumeration value=\"OK\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Finished and validated.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Finished\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Finished but not yet validated.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"MissingPunch\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Missing punch.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Disqualified\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Disqualified (for some other reason than a missing punch).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"DidNotFinish\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Did not finish (i.e. conciously cancelling the race after having started, in contrast to MissingPunch).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Active\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Currently on course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Inactive\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Has not yet started.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"OverTime\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Overtime, i.e. did not finish within the maximum time set by the organiser.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"SportingWithdrawal\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Sporting withdrawal (e.g. helping an injured competitor).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"NotCompeting\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Not competing (i.e. running outside the competition).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Moved\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Moved to another class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"MovedUp\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Moved to a \"better\" class, in case of entry restrictions.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"DidNotStart\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Did not start (in this race).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"DidNotEnter\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Did not enter (in this race).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","      \u003cxsd:enumeration value=\"Cancelled\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The competitor has cancelled his/hers entry.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:enumeration\u003e","    \u003c/xsd:restriction\u003e","  \u003c/xsd:simpleType\u003e","","  \u003cxsd:complexType name=\"ControlAnswer\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines the the selected answer, the correct answer and the time used on a Trail-O control.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Answer\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The answer that the competitor selected. If the competitor did not give any answer, use an empty string.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CorrectAnswer\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The correct answer. If no answer is correct, use an empty string.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Time\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time in seconds used to give the answer, in case of a timed control. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"SplitTime\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a split time at a control.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"ControlCode\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The code of the control.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Time\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The time, in seconds, elapsed from start to punching the control. Fractions of seconds (e.g. 258.7) may be used if the time resolution is higher than one second.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"status\" use=\"optional\" default=\"OK\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The status of the split time.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"OK\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Control belongs to the course and has been punched (either by electronical punching or pin punching). If the time is not available or invalid, omit the Time element.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"Missing\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Control belongs to the course but has not been punched.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"Additional\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Control does not belong to the course, but the competitor has punched it.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Route\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a route, i.e. a number of geographical positions (waypoints) describing a competitor's navigation throughout a course.","","        As routes contain large amounts of information, a compact storage format is utilized to keep the overall file size small. A route is stored as a base64-encoded byte sequence of waypoints. A waypoint is represented as described below. All multi-byte data types are stored in big-endian byte order (most significant byte first). Typically, a one-hour route with one-second waypoint recording interval occupies around 20 kilobytes.","","","        Waypoint header byte","        ====================","        Each waypoint byte sequence starts with a waypoint header byte:","        Waypoint header byte, bit 1: Waypoint type. 0 for normal waypoint, 1 for interruption waypoint. An interruption waypoint is a waypoint that is the last waypoint before an interruption in the route occurs, e.g. due to a satellite signal receiving failure. The last waypoint of a route should be a normal waypoint, not an interruption waypoint.","        Waypoint header byte, bits 2 and 3: Time storage mode. For a description of the time storage modes, see below.","        Bit 2   Bit 3   Time storage mode","        0      0      full storage mode (6 bytes)","        1      0      milliseconds delta storage mode (2 bytes)","        0      1      seconds delta storage mode (1 byte)","        Waypoint header byte, bits 4 and 5: Position storage mode (latitude, longitude, and altitude (if present)). For a description of the position storage modes, see below.","        Bit 4   Bit 5   Position storage mode","        0      0      full storage mode (4 + 4 (+ 3) bytes for latitude, longitude and altitude (if present))","        1      0      big delta delta storage mode (2 + 2 (+ 1) bytes)","        0      1      small delta storage mode (1 + 1 (+ 1) bytes)","        Waypoint header byte, bit 6: Altitude presence. 0 if an altitude value is not present, 1 if it is present.","        Waypoint header byte, bit 7: Unused, always 0.","        Waypoint header byte, bit 8: Unused, always 0.","","","        Time byte sequence","        ==================","        After the waypoint byte comes the time byte sequence. Depending on the time storage mode defined in the waypoint header, the time byte sequence is either 6 bytes (full), 2 bytes (milliseconds delta) or 1 byte (seconds delta) long.","","        Full storage mode","        -----------------","        The following 6 bytes are an unsigned 48-bit integer defining the waypoint's time as the number of milliseconds (1/1000 seconds) since January 1, 1900, 00:00:00 UTC.","","        Milliseconds delta storage mode","        -------------------------------","        The following 2 bytes are an unsigned 16-bit integer defining the waypoint's time as the number of milliseconds to add to the last waypoint's time.","","        Seconds delta storage mode","        --------------------------","        The following byte is an unsigned 8-bit integer defining the waypoint's time as the number of seconds to add to the last waypoint's time. This storage mody can only be used when the difference to the last waypoint's time is an integer value.","","        Consequently:","        - seconds delta storage mode is used when the waypoint's time is less than 256 seconds later than the last waypoint's time, and the difference between the times is an integer value.","        - milliseconds delta storage mode is used when the waypoint's time is less than 65.536 seconds later than the last waypoint's time","        - otherwise, full storage mode is used","        The time of the first waypoint of a route is always stored in full storage mode.","","","        Position byte sequence","        ======================","        Next, the position byte sequence appears: latitude, longitude and (if present) altitude bytes. Depending on the position storage mode defined in the waypoint header, the position byte sequence is either 4 + 4 (+ 3) bytes (full), 2 + 2 (+ 1) bytes (big delta) or 1 + 1 (+ 1) bytes (small delta) long.","","        Full storage mode","        -----------------","        The first 4 bytes are a signed 32-bit integer defining the waypoint's latitude as microdegrees (1/1000000 degrees) relative to the equator. A negative value implies a latitude south of the equator. A microdegree is approximately equivalent to 0.1 meters.","        The following 4 bytes are a signed 32-bit integer defining the waypoint's latitude as microdegrees (1/1000000 degrees) relative to the Greenwich meridian. A negative value implies a longitude west of the Greenwich meridian. A microdegree is approximately equivalent to 0.1 meters at the equator and infinitely small at the poles.","        If the altitude presence bit in the waypoint header bit is set to 1, the following 3 bytes are a signed 24-bit integer defining the waypoint's altitude as decimeters (1/10 meters) relative to the sea level.","","        Big delta storage mode","        ----------------------","        The first 2 bytes are a signed 16-bit integer defining the waypoint's latitude as the number of microdegrees to add to the last waypoint's latitude.","        The following 2 bytes are a signed 16-bit integer defining the waypoint's longitude as the number of microdegrees to add to the last waypoint's longitude.","        If the altitude presence bit in the waypoint header bit is set to 1, the following byte is a signed 8-bit integer defining the waypoint's altitude as the number of decimeters to add to the last waypoint's altitude.","","        Small delta storage mode","        ----------------------","        The first byte is a signed 8-bit integer defining the waypoint's latitude as the number of microdegrees to add to the last waypoint's latitude.","        The following byte is a signed 8-bit integer defining the waypoint's longitude as the number of microdegrees to add to the last waypoint's longitude.","        If the altitude presence bit in the waypoint header bit is set to 1, the following byte is a signed 8-bit integer defining the waypoint's altitude as the number of decimeters to add to the last waypoint's altitude.","","        Consequently:","        - small delta storage mode is used when the waypoint's latitude and longitude is within -0.000128 to 0.000127 degrees from the last waypoint's latitude, and when the altitude is not present or is within -12.8 to 12.7 meters from the last waypoint's altitude","        - big delta storage mode is used when the waypoint's latitude and longitude is within -0.032768 to 0.032767 degrees from the last waypoint's latitude, and when the altitude is not present or is within -12.8 to 12.7 meters from the last waypoint's altitude","        - otherwise, full storage mode is used","        The position of the first waypoint of a route is always stored in full storage mode.","","        Code libraries for reading and writing route data is found in https://github.com/international-orienteering-federation/datastandard-v3/tree/master/libraries.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:extension base=\"xsd:base64Binary\"/\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Leg\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines extra information for a relay leg.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the leg, if not sequentially named.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"minNumberOfCompetitors\" type=\"xsd:integer\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The minimum number of competitors in case of a parallel leg.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"maxNumberOfCompetitors\" type=\"xsd:integer\" use=\"optional\" default=\"1\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The maximum number of competitors in case of a parallel leg.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Control\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a control, without any relationship to a particular course.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The code of the control.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PunchingUnitId\" type=\"Id\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            If the control has multiple punching units with separate codes, specify all these codes using elements of this kind. Omit this element if there is a single punching unit whose code is the same as the control code.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Name\" type=\"LanguageString\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the control, used for e.g. online controls ('spectator control', 'prewarning').","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Position\" type=\"GeoPosition\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The geographical position of the control.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapPosition\" type=\"MapPosition\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position of the control according to tha map's coordinate system.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" type=\"ControlType\" use=\"optional\" default=\"Control\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of the control: (ordinary) control, start, finish, crossing point or end of marked route. This attribute can be overridden on the CourseControl level.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"GeoPosition\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a geographical position, e.g. of a control.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:attribute name=\"lng\" type=\"xsd:double\" use=\"required\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The longitude.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"lat\" type=\"xsd:double\" use=\"required\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The latitude.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"alt\" type=\"xsd:double\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The altitude (elevation above sea level), in meters.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Map\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Map information, used in course setting software with regard to the \"real\" map.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Image\" type=\"Image\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The map image.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Scale\" type=\"xsd:double\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The denominator of the scale of the map. 1:15000 should be represented as 15000.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapPositionTopLeft\" type=\"MapPosition\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position of the map's top left corner given in the map's coordinate system, usually (0, 0).","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapPositionBottomRight\" type=\"MapPosition\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The position of the map's bottom right corner given in the map's coordinate system.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Image\"\u003e","    \u003cxsd:simpleContent\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Defines an image file, either as a link (use the url attribute) or as base64-encoded binary data.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:extension base=\"xsd:base64Binary\"\u003e","        \u003cxsd:attribute name=\"url\" type=\"xsd:string\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The url to the image if it is stored externally (i.e. not as base64-encoded binary data).","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","        \u003cxsd:attribute name=\"mediaType\" type=\"xsd:string\" use=\"required\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The type of the image file, e.g. image/jpeg. Refer to https://www.iana.org/assignments/media-types/media-types.xhtml#image for available media types.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","        \u003cxsd:attribute name=\"width\" type=\"xsd:integer\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The width of the image in pixels.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","        \u003cxsd:attribute name=\"height\" type=\"xsd:integer\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The height of the image in pixels.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","        \u003cxsd:attribute name=\"resolution\" type=\"xsd:double\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The resolution of the image in dpi.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:simpleContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"MapPosition\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a position in a map's coordinate system.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:attribute name=\"x\" type=\"xsd:double\" use=\"required\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The number of units right of the center of the coordinate system.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"y\" type=\"xsd:double\" use=\"required\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The number of units below the center of the coordinate system.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"unit\" use=\"optional\" default=\"mm\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of unit used.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"px\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Pixels, used when the map is represented by a digital image.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","          \u003cxsd:enumeration value=\"mm\"\u003e","            \u003cxsd:annotation\u003e","              \u003cxsd:documentation\u003e","                Millimeters, used when the map is represented by a printed piece of paper.","              \u003c/xsd:documentation\u003e","            \u003c/xsd:annotation\u003e","          \u003c/xsd:enumeration\u003e","        \u003c/xsd:restriction\u003e","      \u003c/xsd:simpleType\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"RaceCourseData\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        This element defines all the control and course information for a race.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Map\" type=\"Map\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The map(s) used in this race. Usually just one map, but different courses may use different scales and/or areas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Control\" type=\"Control\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            All controls of the race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Course\" type=\"Course\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            All courses of the race.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ClassCourseAssignment\" type=\"ClassCourseAssignment\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The assignment of courses to classes.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PersonCourseAssignment\" type=\"PersonCourseAssignment\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The assignment of courses to individual competitors.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamCourseAssignment\" type=\"TeamCourseAssignment\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The assignment of courses to relay team members teams.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"ClassCourseAssignment\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Element that connects a course with a class. Courses should be present in the RaceCourseData element and are matched on course name and/or course family. Classes are matched by 1) Id, 2) Name.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"ClassId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id of the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e        ","      \u003cxsd:element name=\"ClassName\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the class.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"AllowedOnLeg\" type=\"xsd:integer\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The legs that the course can be assigned to in a relay class. This element can be omitted for individual classes.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseFamily\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The family or group of forked courses that the course is part of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"numberOfCompetitors\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The number of competitors in the class. A competitor corresponds to a person (if an individual event) or a team (if a team or relay event).","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"PersonCourseAssignment\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Element that connects a course with an individual competitor. Courses should be present in the RaceCourseData element and are matched on course name and/or course family. Persons are matched by 1) BibNumber, 2) EntryId.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this person's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number of the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"PersonName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ClassName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the class that the person belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseFamily\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The family or group of forked courses that the course is part of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamCourseAssignment\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Element that connects a number of team members in a relay team to a number of courses. Teams are matched by 1) BibNumber, 2) TeamName+ClassName.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number of the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the team.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"ClassName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the class that the team belongs to.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamMemberCourseAssignment\" type=\"TeamMemberCourseAssignment\" minOccurs=\"0\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The assignment of courses to team members.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"TeamMemberCourseAssignment\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Element that connects a course with a relay team member. Courses should be present in the RaceCourseData element and are matched on course name and/or course family. Team members are matched by 1) BibNumber, 2) Leg and LegOrder, 3) EntryId.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"EntryId\" type=\"Id\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id corresponding to this person's entry in an EntryList.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"BibNumber\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The bib number of the person or the team that the person belongs to. Omit if the bib number is specified in the TeamCourseAssignment element.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Leg\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            For relay entries, the number of the leg that the person is taking part in.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"LegOrder\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Defines the person's starting order within a team at a parallel relay leg.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"TeamMemberName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the person.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseName\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseFamily\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The family or group of forked courses that the course is part of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"Course\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a course, i.e. a number of controls including start and finish.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseFamily\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The family or group of forked courses that the course is part of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Length\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The length of the course, in meters.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Climb\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The climb of the course, in meters, along the expected best route choice.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseControl\" type=\"CourseControl\" minOccurs=\"2\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The controls, including start and finish, that the course is made up of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapId\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The id of the map used for this course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"numberOfCompetitors\" type=\"xsd:integer\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The number of competitors that this course has been assigned to.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"modifyTime\" type=\"xsd:dateTime\" use=\"optional\"/\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"SimpleCourse\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a course, excluding controls.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Id\" type=\"Id\" minOccurs=\"0\"/\u003e","      \u003cxsd:element name=\"Name\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The name of the course.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"CourseFamily\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The family or group of forked courses that the course is part of.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Length\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The length of the course, in meters.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Climb\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The climb of the course, in meters, along the expected best route choice.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"NumberOfControls\" type=\"xsd:integer\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The number of controls in the course, excluding start and finish.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"SimpleRaceCourse\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        Defines a course for a certain race, excluding controls.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:complexContent\u003e","      \u003cxsd:extension base=\"SimpleCourse\"\u003e","        \u003cxsd:attribute name=\"raceNumber\" type=\"xsd:integer\" use=\"optional\"\u003e","          \u003cxsd:annotation\u003e","            \u003cxsd:documentation\u003e","              The ordinal number of the race that the information belongs to for a multi-race event, starting at 1.","            \u003c/xsd:documentation\u003e","          \u003c/xsd:annotation\u003e","        \u003c/xsd:attribute\u003e","      \u003c/xsd:extension\u003e","    \u003c/xsd:complexContent\u003e","  \u003c/xsd:complexType\u003e","","  \u003cxsd:complexType name=\"CourseControl\"\u003e","    \u003cxsd:annotation\u003e","      \u003cxsd:documentation\u003e","        A control included in a particular course.","      \u003c/xsd:documentation\u003e","    \u003c/xsd:annotation\u003e","    \u003cxsd:sequence\u003e","      \u003cxsd:element name=\"Control\" type=\"xsd:string\" minOccurs=\"1\" maxOccurs=\"unbounded\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The code(s) of the control(s), without course-specific information. Specifying multiple control codes means that the competitor is required to punch one of the controls, but not all of them.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapText\" type=\"xsd:string\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Indicates the text shown next to the control circle, i.e. the control number.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"MapTextPosition\" type=\"MapPosition\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Indicates the position of the center of the text relative to the center of the control circle.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"LegLength\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The length in meters from the previous control on the course. For starts, this length may refer to the distance from the time start to the start flag.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Score\" type=\"xsd:double\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            The score of the control in score-O events.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","      \u003cxsd:element name=\"Extensions\" type=\"Extensions\" minOccurs=\"0\"\u003e","        \u003cxsd:annotation\u003e","          \u003cxsd:documentation\u003e","            Container element for custom elements from other schemas.","          \u003c/xsd:documentation\u003e","        \u003c/xsd:annotation\u003e","      \u003c/xsd:element\u003e","    \u003c/xsd:sequence\u003e","    \u003cxsd:attribute name=\"type\" type=\"ControlType\" use=\"optional\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          The type of the control: (ordinary) control, start, finish, crossing point or end of marked route. If this attribute is specified, it overrides the corresponding Control's type.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"randomOrder\" type=\"xsd:boolean\" use=\"optional\" default=\"false\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Non-broken sequences of course controls having randomOrder set to true can be visited in an arbitrary order.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","    \u003c/xsd:attribute\u003e","    \u003cxsd:attribute name=\"specialInstruction\" use=\"optional\" default=\"None\"\u003e","      \u003cxsd:annotation\u003e","        \u003cxsd:documentation\u003e","          Any special instruction applied at the control, see the column G as defined in International Specification for Control Descriptions.","        \u003c/xsd:documentation\u003e","      \u003c/xsd:annotation\u003e","      \u003cxsd:simpleType\u003e","        \u003cxsd:restriction base=\"xsd:NMTOKEN\"\u003e","          \u003cxsd:enumeration value=\"None\"/\u003e","          \u003cxsd:enumeration value=\"TapedRoute\"/\u003e","          \u003cxsd:enumeration value=\"FunnelTapedRoute\"/\u003e","          \u003cxsd:enumeration value=\"MandatoryCrossingPoint\"/\u003e","          \u003cxsd:enumeration value=\"MandatoryOutOfBoundsAreaPassage\"/\u003e","        \u003c/xsd:restriction\u003e","  